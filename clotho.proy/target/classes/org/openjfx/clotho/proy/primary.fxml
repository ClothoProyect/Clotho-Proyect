<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.cell.PropertyValueFactory?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
	prefHeight="768.0" prefWidth="1024.0" 
	style="-fx-background-color: #9370db; -fx-font-weight: bold;"
	xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
	fx:controller="org.openjfx.clotho.proy.PrimaryController">
   <top>
      <VBox prefHeight="100.0" prefWidth="1024.0" BorderPane.alignment="CENTER">
         <children>
            <ToolBar prefHeight="40.0" prefWidth="200.0">
              <items>
                <Button mnemonicParsing="false" text="Buscar pedido" />
                  <Button mnemonicParsing="false" text="Realizar Backup" />
                  <Button mnemonicParsing="false" text="Salir" />
              </items>
            </ToolBar>
            <GridPane hgap="10.0" prefHeight="60.0" vgap="5.0">
              <columnConstraints>
                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
                  <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
                  <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="50.0" />
                  <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Label text="Cliente:" />
                  <TextField fx:id="txtCliente" promptText="Nombre del cliente" GridPane.columnIndex="1" />
                  <Label text="Fecha" GridPane.columnIndex="2" />
                  <DatePicker fx:id="dpConsegna" GridPane.columnIndex="3" />
               </children>
               <VBox.margin>
                  <Insets left="10.0" right="10.0" top="10.0" />
               </VBox.margin>
            </GridPane>
         </children>
      </VBox>
   </top>
   <center>
      <TableView fx:id="tablaServicios" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
    <columnResizePolicy>
        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
    </columnResizePolicy>
    <columns>
        <TableColumn text="Servicio">
            <cellValueFactory>
                <PropertyValueFactory property="nombre" />
            </cellValueFactory>
        </TableColumn>
        
        <TableColumn text="Precio">
            <cellValueFactory>
                <PropertyValueFactory property="precio" />
            </cellValueFactory>
        </TableColumn>
        
        <TableColumn text="Descripción">
            <cellValueFactory>
                <PropertyValueFactory property="descripcion" />
            </cellValueFactory>
        </TableColumn>
        
        </columns>
</TableView>
   </center>
   <right>
      <VBox prefHeight="200.0" prefWidth="200.0" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" 
        text="Añadir Cliente" onAction="#abrirVentanaNuevoCliente" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false"
            text="Añadir Servicio" onAction="#abrirVentanaServicios" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false"
            text="Añadir Pedido" onAction="#procesarPedido"/>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </VBox>
   </right>
   <bottom>
      <HBox prefHeight="100.0" prefWidth="200.0" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <VBox prefHeight="100.0" prefWidth="180.0">
               <children>
                  <ImageView fitHeight="60.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@zyp_logo.png" /> </image>
                  </ImageView>
                  <Label text="Clotho" />
               </children>
            </VBox>
            <Button mnemonicParsing="false" text="Consultar Pedido" />
            <Button mnemonicParsing="false" text="Cancelar" 
            onAction="#handleCancelar"/>
            <Button mnemonicParsing="false" text="A Pagar" 
            onAction="#handleAPagar"/>
            <Button mnemonicParsing="false" text="Pagado" 
            onAction="#handlePagado"/>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>